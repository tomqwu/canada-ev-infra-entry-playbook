---
interface Option {
  id: string;
  label: string;
  title: string;
  thesis: string;
  capitalNeed: string;
  timeline: string;
  risk: string;
  expectedReturn: string;
  milestones: string[];
  recommended?: boolean;
}

interface Props {
  options: Option[];
}

const { options } = Astro.props as Props;
---

<div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
  {
    options.map((o) => (
      <article
        class={`card card-pad flex flex-col ${o.recommended ? "border-accent-500 ring-1 ring-accent-500/40" : ""}`}
      >
        <div class="flex items-center justify-between mb-3">
          <span class="tag">{o.label}</span>
          {o.recommended && (
            <span class="tag-accent">Recommended</span>
          )}
        </div>
        <h3 class="font-serif text-xl text-ink leading-snug">{o.title}</h3>
        <p class="mt-3 text-sm text-ink/80 leading-relaxed">{o.thesis}</p>

        <dl class="mt-5 grid grid-cols-2 gap-x-4 gap-y-3 text-sm">
          <div>
            <dt class="text-[11px] uppercase tracking-wider text-ink-muted">
              Capital need
            </dt>
            <dd class="mt-0.5 text-ink">{o.capitalNeed}</dd>
          </div>
          <div>
            <dt class="text-[11px] uppercase tracking-wider text-ink-muted">
              Timeline
            </dt>
            <dd class="mt-0.5 text-ink">{o.timeline}</dd>
          </div>
          <div>
            <dt class="text-[11px] uppercase tracking-wider text-ink-muted">
              Risk
            </dt>
            <dd class="mt-0.5 text-ink">{o.risk}</dd>
          </div>
          <div>
            <dt class="text-[11px] uppercase tracking-wider text-ink-muted">
              Expected return
            </dt>
            <dd class="mt-0.5 text-ink">{o.expectedReturn}</dd>
          </div>
        </dl>

        <div class="mt-5 pt-5 border-t border-line">
          <p class="text-[11px] uppercase tracking-wider text-ink-muted mb-2">
            Key milestones
          </p>
          <ul class="space-y-1.5 text-sm text-ink/85">
            {o.milestones.map((m) => (
              <li class="flex gap-2">
                <span class="text-accent-600 mt-1">›</span>
                <span>{m}</span>
              </li>
            ))}
          </ul>
        </div>
      </article>
    ))
  }
</div>
