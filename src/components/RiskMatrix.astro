---
interface Risk {
  id: string;
  title: string;
  category: string;
  likelihood: string;
  impact: string;
  narrative: string;
  mitigations: string[];
}

interface Props {
  risks: Risk[];
}

const { risks } = Astro.props as Props;

function levelClass(level: string): string {
  if (level === "High") return "tag-risk";
  if (level === "Medium") return "tag-warn";
  return "tag-accent";
}
---

<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
  {
    risks.map((r) => (
      <article class="card card-pad">
        <div class="flex flex-wrap items-center gap-2 mb-3">
          <span class="tag">{r.category}</span>
          <span class={levelClass(r.likelihood)}>Likelihood: {r.likelihood}</span>
          <span class={levelClass(r.impact)}>Impact: {r.impact}</span>
        </div>
        <h3 class="font-serif text-lg text-ink leading-snug">{r.title}</h3>
        <p class="mt-2 text-sm text-ink/85 leading-relaxed">{r.narrative}</p>
        <div class="mt-4 pt-4 border-t border-line">
          <p class="text-[11px] uppercase tracking-wider text-ink-muted mb-2">
            Mitigations
          </p>
          <ul class="space-y-1.5 text-sm text-ink/85">
            {r.mitigations.map((m) => (
              <li class="flex gap-2">
                <span class="text-accent-600 mt-1">›</span>
                <span>{m}</span>
              </li>
            ))}
          </ul>
        </div>
      </article>
    ))
  }
</div>
