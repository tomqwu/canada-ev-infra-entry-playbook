---
import { withBase } from "../lib/url";

interface CTAItem {
  label: string;
  href: string;
  style?: "primary" | "secondary" | "accent";
  external?: boolean;
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actions: CTAItem[];
  variant?: "block" | "inline";
}

const {
  eyebrow,
  title,
  description,
  actions,
  variant = "block",
} = Astro.props as Props;

function btnClass(style: CTAItem["style"]): string {
  if (style === "secondary") return "btn-secondary";
  if (style === "accent") return "btn-accent";
  return "btn-primary";
}
---

{
  variant === "block" ? (
    <section class="rounded-2xl bg-navy-900 text-white px-6 sm:px-10 py-12 sm:py-16">
      <div class="max-w-3xl">
        {eyebrow && (
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-300 mb-3">
            {eyebrow}
          </p>
        )}
        <h2 class="font-serif text-3xl sm:text-4xl leading-tight">{title}</h2>
        {description && (
          <p class="mt-4 text-navy-100 text-lg leading-relaxed">{description}</p>
        )}
        <div class="mt-8 flex flex-wrap gap-3">
          {actions.map((a) => (
            <a
              href={a.external ? a.href : withBase(a.href)}
              class={btnClass(a.style)}
              {...(a.external ? { target: "_blank", rel: "noreferrer" } : {})}
            >
              {a.label}
            </a>
          ))}
        </div>
      </div>
    </section>
  ) : (
    <div class="flex flex-wrap gap-3">
      {actions.map((a) => (
        <a
          href={a.external ? a.href : withBase(a.href)}
          class={btnClass(a.style)}
          {...(a.external ? { target: "_blank", rel: "noreferrer" } : {})}
        >
          {a.label}
        </a>
      ))}
    </div>
  )
}
