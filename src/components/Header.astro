---
import { withBase } from "../lib/url";

const nav = [
  { label: "Overview", href: "/" },
  { label: "Strategy", href: "/strategy" },
  { label: "Research", href: "/research" },
  { label: "Financials", href: "/financials" },
  { label: "Roadmap", href: "/roadmap" },
  { label: "Pitch", href: "/pitch" },
  { label: "Sources", href: "/sources" },
];

const pathname = Astro.url.pathname;
const baseUrl = (import.meta.env.BASE_URL ?? "/").toString();
const trimmedBase = baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl;

function isActive(href: string): boolean {
  const target = withBase(href);
  if (href === "/") {
    return pathname === target || pathname === `${target}/` || pathname === `${trimmedBase}/`;
  }
  return pathname === target || pathname.startsWith(`${target}/`);
}
---

<header class="border-b border-line bg-white/85 backdrop-blur sticky top-0 z-30">
  <div class="container-page flex items-center justify-between h-16">
    <a href={withBase("/")} class="flex items-center gap-2.5 no-underline">
      <span
        class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-navy-900 text-white font-serif text-sm"
        aria-hidden="true">CA</span
      >
      <span class="font-semibold text-ink tracking-tightish">
        Canada EV Infra Playbook
      </span>
    </a>
    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-1">
        {
          nav.map((item) => {
            const active = isActive(item.href);
            return (
              <li>
                <a
                  href={withBase(item.href)}
                  class={`px-3 py-2 text-sm rounded-md no-underline transition-colors ${active ? "bg-navy-50 text-navy-800 font-semibold" : "text-ink/80 hover:text-navy-800 hover:bg-navy-50/60"}`}
                  aria-current={active ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
    <details class="md:hidden relative">
      <summary
        class="list-none cursor-pointer px-3 py-2 text-sm rounded-md border border-line text-ink-muted"
        aria-label="Open navigation"
      >
        Menu
      </summary>
      <div
        class="absolute right-0 mt-2 w-56 rounded-lg border border-line bg-white shadow-card overflow-hidden"
      >
        <ul>
          {
            nav.map((item) => (
              <li>
                <a
                  href={withBase(item.href)}
                  class="block px-4 py-2 text-sm text-ink/85 hover:bg-navy-50 no-underline"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </details>
  </div>
</header>
