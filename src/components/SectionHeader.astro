---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  as?: "h1" | "h2" | "h3";
}

const {
  eyebrow,
  title,
  description,
  align = "left",
  as: Tag = "h2",
} = Astro.props as Props;

const alignClasses =
  align === "center" ? "text-center mx-auto max-w-3xl" : "text-left max-w-3xl";
---

<header class={`mb-10 ${alignClasses}`}>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <Tag class="heading-section">{title}</Tag>
  {description && <p class="lead mt-4">{description}</p>}
</header>
