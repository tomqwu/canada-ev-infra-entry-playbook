---
import CTA from "./CTA.astro";

interface CTAItem {
  label: string;
  href: string;
  style?: "primary" | "secondary" | "accent";
  external?: boolean;
}

interface Props {
  eyebrow?: string;
  title: string;
  lede: string;
  meta?: { label: string; value: string }[];
  actions?: CTAItem[];
}

const { eyebrow, title, lede, meta = [], actions = [] } = Astro.props as Props;
---

<section class="relative overflow-hidden bg-navy-900 text-white">
  <div
    class="absolute inset-0 opacity-30 pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(60% 60% at 20% 10%, rgba(58,142,89,0.35) 0%, rgba(10,20,40,0) 60%), radial-gradient(50% 50% at 90% 90%, rgba(94,124,180,0.35) 0%, rgba(10,20,40,0) 60%);"
  >
  </div>
  <div class="container-page relative py-20 sm:py-28">
    <div class="max-w-3xl">
      {
        eyebrow && (
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-300 mb-5">
            {eyebrow}
          </p>
        )
      }
      <h1 class="heading-display text-white">{title}</h1>
      <p class="lead mt-6 text-navy-100">{lede}</p>
      {
        actions.length > 0 && (
          <div class="mt-10">
            <CTA title="" actions={actions} variant="inline" />
          </div>
        )
      }
    </div>
    {
      meta.length > 0 && (
        <dl class="mt-14 grid grid-cols-1 sm:grid-cols-3 gap-x-10 gap-y-6 max-w-3xl border-t border-white/10 pt-8">
          {meta.map((m) => (
            <div>
              <dt class="text-xs uppercase tracking-[0.18em] text-navy-200">
                {m.label}
              </dt>
              <dd class="mt-1 font-serif text-2xl text-white">{m.value}</dd>
            </div>
          ))}
        </dl>
      )
    }
  </div>
</section>
