---
import { getCollection, type CollectionEntry } from "astro:content";
import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/url";

export async function getStaticPaths() {
  const reports = await getCollection("reports");
  return reports.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"reports">;
}

const { entry } = Astro.props as Props;
const { Content } = await entry.render();

function formatDate(d: Date): string {
  return d.toLocaleDateString("en-CA", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

function statusClass(s: string): string {
  if (s === "published") return "tag-accent";
  if (s === "in-review") return "tag-warn";
  return "tag";
}
---

<Base title={entry.data.title} description={entry.data.summary}>
  <article class="container-page py-16 sm:py-20">
    <p class="text-sm mb-6">
      <a href={withBase("/research")}>← Back to research</a>
    </p>

    <div class="flex flex-wrap items-center gap-2 mb-5">
      <span class={statusClass(entry.data.status)}>{entry.data.status}</span>
      <span class="tag">{entry.data.audience}</span>
      {entry.data.tags.map((t) => <span class="tag">{t}</span>)}
    </div>

    <h1 class="heading-display text-ink">{entry.data.title}</h1>
    <p class="lead mt-4 max-w-prose">{entry.data.summary}</p>

    <div
      class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-ink-muted"
    >
      <span>Author: {entry.data.author}</span>
      <span>Updated {formatDate(entry.data.lastUpdated)}</span>
      {
        entry.data.sources.length > 0 && (
          <span>
            Sources:{" "}
            {entry.data.sources.map((s, i) => (
              <>
                <code class="font-mono text-[11px]">{s}</code>
                {i < entry.data.sources.length - 1 && ", "}
              </>
            ))}
          </span>
        )
      }
    </div>

    <div class="mt-10 prose-memo">
      <Content />
    </div>
  </article>
</Base>
